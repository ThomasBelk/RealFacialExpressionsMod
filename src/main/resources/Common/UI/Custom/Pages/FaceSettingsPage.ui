$C = "../Common.ui";
$C.@Container {
    Anchor: (Width: 800, Height: 500);

    #Title {
        $C.@Title { @Text = "Real Facial Expressions Settings"; }
    }

    #Content {
        Group {
            Padding: (Left: 20, Right: 20);
            FlexWeight: 1;
            $C.@FloatSlider #BrowThreshold {
                Min: 0;
                Max: 1;
                Step: 0.01;
            }
        }
        Group {
            Padding: (Left: 20, Right: 20);
            FlexWeight: 1;
            $C.@FloatSlider #EyeLidClosedThreshold {
                Min: 0;
                Max: 1;
                Step: 0.01;
            }
        }
        Group {
            Padding: (Left: 20, Right: 20);
            FlexWeight: 1;
            $C.@FloatSlider #EyeLidHalfOpenThreshold {
                Min: 0;
                Max: 1;
                Step: 0.01;
            }
        }
        Group {
            Padding: (Left: 20, Right: 20);
            FlexWeight: 1;
            $C.@FloatSlider #SmileThreshold {
                Min: 0;
                Max: 1;
                Step: 0.01;
            }
        }
        Group {
            Padding: (Left: 20, Right: 20);
            FlexWeight: 1;
            $C.@FloatSlider #MouthOpenThreshold {
                Min: 0;
                Max: 1;
                Step: 0.01;
            }
        }
        Group {
            Padding: (Left: 20, Right: 20);
            FlexWeight: 1;
            $C.@SecondaryTextButton #ResetButton {
                @Anchor = (Width: 180);
                @Text = "Reset To Defaults";
            }
        }
    }
